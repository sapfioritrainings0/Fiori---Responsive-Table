<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:form="sap.ui.layout.form">

<Dialog id="dialog" title="Add Product" contentWidth="32rem">

<form:SimpleForm layout="ResponsiveGridLayout" editable="true">
<form:content>

<Label text="ID" required="true"></Label>
<Input id="inputId" value="{newProduct>/ID}" placeholder="Enter ID"/>

<Label text="Name" required="true"></Label>
<Input id="inputName" value="{newProduct>/Name}" placeholder="Enter Name"/>

<Label text="Description" ></Label>
<TextArea id="inputDescription" rows="2" width="100%" value="{newProduct>/Description}" placeholder="Enter Description"></TextArea>

<Label text="Release Date"></Label>
<DatePicker id="inputReleaseDate" displayFormat="dd-MM-yyyy" value="{path:'newProduct>/ReleaseDate', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd-MM-yyyy' }}" placeholder="dd-MM-yyyy"></DatePicker>

<Label text="Rating"></Label>
<StepInput id="inputRating" min="0" max="5" step="1" value="{newProduct>/Rating}"></StepInput>

<Label text="Price" required="true"></Label>
<Input id="inputPrice" placeholder="0.00" value="{newProduct>/Price}" type="Number" />
</form:content>


</form:SimpleForm>

<beginButton>
	<Button text="Create" type="Accept" press="onCreateProduct"/>
</beginButton>
<endButton>
	<Button text="Cancel" type="Reject" press="onCloseDialog"/>
</endButton>


</Dialog>



</core:FragmentDefinition>